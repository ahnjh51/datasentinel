# DataSentinel Environment Variables Example
# Duplicate this file as .env and fill in active keys

# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=datasentinel-gcp-key.json

# API Integrations
# Gemini API Key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key

# Discord Webhook for structured SRE alerts
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# GitHub repository configuration
GITHUB_REPO=ahnjh51/datasentinel
GITHUB_PAT=your-github-personal-access-token

# Ingestion configuration
CITYBIKES_NETWORK_ID=docomo-tokyo
